{
  "compilerOptions": {
    "target": "ES2017",
    "module": "commonjs",
    "lib": ["es2017"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "outDir": ".",
    "rootDir": ".",
    "resolveJsonModule": true
  },
  "include": ["server.ts"],
  "exclude": ["node_modules", "src", ".next"]
}
